{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "espaco-bem-estar",
  "description": "Espaço Bem Estar - Casa de Repouso Feminina em Uberlândia",
  "public": true,
  "github": {
    "enabled": true,
    "autoJobCancelation": true
  },
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/sobre",
      "dest": "/sobre.html"
    },
    {
      "src": "/estrutura",
      "dest": "/estrutura.html"
    },
    {
      "src": "/contato",
      "dest": "/index.html#contato"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/src/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/src/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/src/img/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sobre",
      "destination": "/sobre.html"
    },
    {
      "source": "/estrutura",
      "destination": "/estrutura.html"
    }
  ]
}
